---
// Light/dark pill toggle. Knob slides left (light) ↔ right (dark) and carries
// the active icon; the faint icon on the empty side stays put underneath.
// Reproduces ThemeToggle in landing-themed.jsx. Flips data-theme on <html>.
---

<button class="theme-toggle" type="button" aria-label="Toggle theme">
  <span class="tg-side tg-side--left">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="4.5"></circle>
      <path
        d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.2 5.2l1.4 1.4M17.4 17.4l1.4 1.4M18.8 5.2l-1.4 1.4M6.6 17.4l-1.4 1.4"
      ></path>
    </svg>
  </span>
  <span class="tg-side tg-side--right">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="none"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
    </svg>
  </span>
  <span class="tg-knob">
    <span class="tg-knob-icon tg-knob-icon--sun">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="4.5"></circle>
        <path
          d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.2 5.2l1.4 1.4M17.4 17.4l1.4 1.4M18.8 5.2l-1.4 1.4M6.6 17.4l-1.4 1.4"
        ></path>
      </svg>
    </span>
    <span class="tg-knob-icon tg-knob-icon--moon">
      <svg
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </span>
  </span>
</button>

<style>
  .theme-toggle {
    width: 64px;
    height: 32px;
    border-radius: 32px;
    border: none;
    cursor: pointer;
    background: var(--toggle-track);
    position: relative;
    padding: 0;
    flex-shrink: 0;
    transition: background 240ms ease;
  }
  .tg-side {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tg-side--left {
    left: 0;
  }
  .tg-side--right {
    left: 32px;
  }
  .tg-side svg {
    stroke: var(--toggle-icon-off);
  }
  .tg-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 26px;
    height: 26px;
    border-radius: 26px;
    background: var(--toggle-knob);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgb(0 0 0 / 18%);
    transition:
      left 260ms cubic-bezier(0.2, 0.9, 0.3, 1.2),
      background 240ms ease;
  }
  :global([data-theme='dark']) .tg-knob {
    left: 35px;
  }
  .tg-knob svg {
    stroke: var(--toggle-icon-on);
  }
  .tg-knob-icon {
    display: inline-flex;
  }
  .tg-knob-icon--moon {
    display: none;
  }
  :global([data-theme='dark']) .tg-knob-icon--sun {
    display: none;
  }
  :global([data-theme='dark']) .tg-knob-icon--moon {
    display: inline-flex;
  }
</style>

<script>
  const KEY = 'streaq-theme';
  document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem(KEY, next);
      } catch {
        /* ignore unavailable storage */
      }
    });
  });
</script>
