---
// Email capture. Inline row on desktop; stacked inside .layout-mobile.
// Submits to a Kit (formerly ConvertKit) form via its public, browser-safe
// subscription endpoint — no API key ships to the client. Set the form's
// numeric id in PUBLIC_KIT_FORM_ID (see .env.example). When unset, the form
// falls back to a visual-only confirmation so local dev still works.
// Mirrors Signup in landing-shared.jsx.
interface Props {
  cta?: string;
  note?: string;
}
const { cta = 'Request an invite', note = 'Beta opens soon' } = Astro.props;
// Public Kit form id (safe to commit). Override per-environment with PUBLIC_KIT_FORM_ID.
const kitFormId = import.meta.env.PUBLIC_KIT_FORM_ID || '9503947';
---

<div class="signup">
  <form class="signup-form" novalidate data-kit-form={kitFormId}>
    <input
      class="signup-input"
      type="email"
      name="email_address"
      placeholder="you@email.com"
      autocomplete="email"
      aria-label="Email address"
    />
    <button class="signup-btn" type="submit" data-cta={cta}>{cta}</button>
  </form>
  <div class="signup-note">{note}</div>
  <div class="signup-error" role="alert" hidden></div>

  <div class="signup-done" hidden>
    <span class="signup-done-icon">
      <svg
        width="14"
        height="14"
        viewBox="0 0 56 56"
        fill="none"
        stroke-width="8"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="12,29 23,40 44,16"></polyline>
      </svg>
    </span>
    <div>
      <div class="signup-done-title">You're on the list.</div>
      <div class="signup-done-sub"></div>
    </div>
  </div>
</div>

<style>
  .signup {
    max-width: 440px;
    width: 100%;
  }

  /* ── desktop: inline row inside a bordered pill field ── */
  .signup-form {
    display: flex;
    flex-direction: row;
    gap: 8px;
    padding: 6px;
    border-radius: 15px;
    background: var(--field-bg);
    border: 1px solid var(--field-border);
  }
  .signup-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    outline: none;
    font-family: var(--font-ui);
    font-size: 16px;
    color: var(--fg);
    padding: 0 14px;
  }
  .signup-input::placeholder {
    color: var(--mute);
  }
  .signup-btn {
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    background: var(--btn-bg);
    color: var(--btn-fg);
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    padding: 13px 22px;
    border-radius: 11px;
    letter-spacing: -0.01em;
    white-space: nowrap;
    transition:
      transform 160ms ease,
      opacity 160ms ease;
  }
  .signup-btn:hover {
    opacity: 0.88;
  }
  .signup-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .signup-note {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--mute);
    letter-spacing: 0.04em;
    margin-top: 13px;
    padding-left: 4px;
    text-transform: uppercase;
  }
  .signup-error {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--error-fg);
    letter-spacing: 0.04em;
    margin-top: 10px;
    padding-left: 4px;
  }
  .signup-error[hidden] {
    display: none;
  }

  /* ── confirmed state ── */
  .signup-done {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-radius: 14px;
    background: var(--confirm-bg);
    border: 1px solid var(--field-border);
    max-width: 440px;
  }
  .signup-done[hidden] {
    display: none;
  }
  .signup-done-icon {
    width: 26px;
    height: 26px;
    border-radius: 8px;
    flex-shrink: 0;
    background: var(--accent-fill);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .signup-done-icon svg {
    stroke: var(--accent-deep);
  }
  .signup-done-title {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    color: var(--fg);
  }
  .signup-done-sub {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--mute);
    letter-spacing: 0.03em;
    margin-top: 2px;
  }

  /* ── mobile: stacked (column), each field gets its own border/bg ── */
  :global(.layout-mobile) .signup {
    max-width: 100%;
  }
  :global(.layout-mobile) .signup-form {
    flex-direction: column;
    gap: 10px;
    padding: 0;
    background: transparent;
    border: none;
  }
  :global(.layout-mobile) .signup-input {
    border: 1px solid var(--field-border);
    background: var(--field-bg);
    padding: 16px;
    border-radius: 13px;
  }
  :global(.layout-mobile) .signup-btn {
    padding: 16px 22px;
    border-radius: 13px;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('.signup-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('.signup-input');
      const button = form.querySelector<HTMLButtonElement>('.signup-btn');
      const email = (input?.value ?? '').trim();
      if (!/.+@.+\..+/.test(email)) {
        input?.focus();
        return;
      }

      const wrap = form.closest('.signup');
      if (!wrap) return;
      const note = wrap.querySelector<HTMLElement>('.signup-note');
      const done = wrap.querySelector<HTMLElement>('.signup-done');
      const sub = wrap.querySelector<HTMLElement>('.signup-done-sub');
      const errorEl = wrap.querySelector<HTMLElement>('.signup-error');

      const showConfirmed = () => {
        if (sub) sub.textContent = `We'll email ${email} when the beta opens.`;
        form.hidden = true;
        if (note) note.hidden = true;
        if (errorEl) errorEl.hidden = true;
        if (done) done.hidden = false;
      };

      // No Kit form configured (e.g. local dev) → visual-only confirmation.
      const formId = form.dataset.kitForm;
      if (!formId) {
        showConfirmed();
        return;
      }

      const cta = button?.dataset.cta ?? button?.textContent ?? '';
      if (button) {
        button.disabled = true;
        button.textContent = 'Joining…';
      }
      if (errorEl) errorEl.hidden = true;

      try {
        // Kit's public form-subscription endpoint. No API key is required or
        // exposed; `Accept: application/json` returns JSON instead of redirecting.
        const res = await fetch(`https://app.convertkit.com/forms/${formId}/subscriptions`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ email_address: email }),
        });
        const data = await res.json().catch(() => ({}) as { status?: string });
        if (res.ok && (data.status ? data.status === 'success' : true)) {
          showConfirmed();
        } else {
          throw new Error(`Kit subscribe failed (${res.status})`);
        }
      } catch (err) {
        if (errorEl) {
          errorEl.textContent = 'Something went wrong — please try again.';
          errorEl.hidden = false;
        }
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = cta;
        }
      }
    });
  });
</script>
