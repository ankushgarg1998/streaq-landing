---
import '../styles/tokens.css';
import BrandLockup from '../components/BrandLockup.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Eyebrow from '../components/Eyebrow.astro';
import DotGrid from '../components/DotGrid.astro';

// Landing page Kit redirects to after a user clicks the double opt-in
// confirmation link in their email. Set this URL (https://streaq.club/confirmed)
// as the form's post-confirmation redirect in the Kit dashboard.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>You're on the list — Streaq</title>
    <meta name="description" content="Your spot on the Streaq waitlist is confirmed." />
    <meta name="theme-color" content="#edeae3" />
    <meta name="robots" content="noindex" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Set the theme before paint to avoid a flash. Defaults to light. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('streaq-theme');
          document.documentElement.setAttribute(
            'data-theme',
            t === 'dark' ? 'dark' : 'light',
          );
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>

  <body>
    <main class="layout">
      <div class="glow" aria-hidden="true"></div>

      <header class="topbar">
        <a class="brand-link" href="/" aria-label="Streaq home"><BrandLockup size={30} /></a>
        <ThemeToggle />
      </header>

      <section class="center">
        <span class="check" aria-hidden="true">
          <svg
            width="22"
            height="22"
            viewBox="0 0 56 56"
            fill="none"
            stroke-width="8"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="12,29 23,40 44,16"></polyline>
          </svg>
        </span>
        <div class="eyebrow"><Eyebrow size={12}>Spot confirmed</Eyebrow></div>
        <h1 class="h1">You're on the <em>streak.</em></h1>
        <p class="p" id="confirm-copy">
          Your place on the waitlist is locked in. We'll email you the moment Streaq opens
          its doors — keep an eye on your inbox.
        </p>
        <a class="home-link" href="/">Back to streaq.club</a>
      </section>

      <div class="band"><DotGrid rows={4} cols={17} dot={17} gap={14} /></div>
    </main>

    <!--
      Personalize from Kit's "Send subscriber data to thank you page" params.
      Kit appends them to the redirect URL (e.g. ?first_name=…&email_address=…&id=…).
      These are user-controllable, so render only via textContent (never innerHTML)
      and cap length. Falls back to the generic copy when params are absent.
    -->
    <script is:inline>
      (function () {
        try {
          var params = new URLSearchParams(location.search);
          var clean = function (v) {
            return (v || '').toString().trim().slice(0, 80);
          };
          var firstName = clean(params.get('first_name'));
          var email = clean(params.get('email_address') || params.get('email'));
          var p = document.getElementById('confirm-copy');
          if (!p || (!firstName && !email)) return;
          var lead = firstName ? 'Welcome, ' + firstName + '! ' : '';
          var mail = email ? 'We’ll email ' + email : 'We’ll email you';
          p.textContent =
            lead +
            'Your place on the waitlist is locked in. ' +
            mail +
            ' the moment Streaq opens its doors — keep an eye on your inbox.';
        } catch (e) {}
      })();
    </script>
  </body>
</html>

<style>
  .layout {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }
  .glow {
    position: absolute;
    top: -120px;
    left: 50%;
    transform: translateX(-50%);
    width: 520px;
    height: 520px;
    border-radius: 520px;
    background: radial-gradient(circle, oklch(0.58 0.11 220 / 0.16), transparent 70%);
    pointer-events: none;
    display: none;
  }
  :global([data-theme='dark']) .glow {
    display: block;
  }
  .topbar {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px 60px;
  }
  .brand-link {
    text-decoration: none;
  }
  .center {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 56px;
    margin-top: 60px;
  }
  .check {
    width: 52px;
    height: 52px;
    border-radius: 15px;
    background: var(--accent-fill);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
  }
  .check svg {
    stroke: var(--accent-deep);
  }
  .eyebrow {
    margin-bottom: 24px;
  }
  .h1 {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 0.98;
    font-size: clamp(48px, 9vw, 88px);
    margin: 0;
    max-width: 820px;
    color: var(--fg);
    text-wrap: balance;
  }
  .h1 em {
    font-style: italic;
    font-weight: 500;
  }
  .p {
    font-size: clamp(16.5px, 2vw, 21px);
    line-height: 1.5;
    color: var(--sub);
    max-width: 540px;
    margin: 26px 0 34px;
    text-wrap: pretty;
  }
  .home-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mute);
    text-decoration: none;
    border-bottom: 1px solid var(--field-border);
    padding-bottom: 2px;
    transition: color 160ms ease;
  }
  .home-link:hover {
    color: var(--fg);
  }
  .band {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    justify-content: center;
    padding-bottom: 50px;
  }

  @media (max-width: 720px) {
    .topbar {
      padding: 14px 28px;
    }
    .center {
      padding: 0 28px;
      margin-top: 40px;
    }
    .band {
      padding-bottom: 32px;
    }
  }
</style>
